@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .
@prefix sfcfg: <https://semantic-flow.github.io/sflo/config/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<_mesh> a sflo:SemanticMesh ;
  sflo:meshBase "https://semantic-flow.github.io/mesh-branch-fantasy-rules/"^^xsd:anyURI ;
  sflo:hasMeshMetadata <_mesh/_meta> ;
  sflo:hasMeshInventory <_mesh/_inventory> ;
  sflo:hasKnop <examples/_knop> ;
  sflo:hasKnop <ontology/_knop> ;
  sflo:hasKnop <shacl/_knop> ;
  sflo:hasKnop <ontology/AbilityScore/_knop> ;
  sflo:hasKnop <ontology/Alignment/_knop> ;
  sflo:hasKnop <ontology/Character/_knop> ;
  sflo:hasKnop <ontology/PlayerCharacter/_knop> ;
  sflo:hasKnop <ontology/CharacterShape/_knop> ;
  sflo:hasKnop <_knop> ;
  sflo:hasResourcePage <_mesh/index.html> .

<_mesh/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_meta> a sflo:MeshMetadata, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <_mesh/_meta/meta.ttl> ;
  sflo:hasResourcePage <_mesh/_meta/index.html> .

<_mesh/_meta/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_inventory> a sflo:MeshInventory, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <_mesh/_inventory/inventory.ttl> ;
  sflo:hasResourcePage <_mesh/_inventory/index.html> .

<_mesh/_inventory/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_config> a sfcfg:MeshConfig, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <_mesh/_config/config.ttl> ;
  sflo:hasResourcePage <_mesh/_config/index.html> ;
  sflo:hasArtifactHistory <_mesh/_config/_history001> ;
  sflo:currentArtifactHistory <_mesh/_config/_history001> ;
  sflo:nextHistoryOrdinal "2"^^xsd:nonNegativeInteger .

<_mesh/_config/_history001> a sflo:ArtifactHistory ;
  sflo:historyOrdinal "1"^^xsd:nonNegativeInteger ;
  sflo:hasHistoricalState <_mesh/_config/_history001/_s0001> ;
  sflo:latestHistoricalState <_mesh/_config/_history001/_s0001> ;
  sflo:nextStateOrdinal "2"^^xsd:nonNegativeInteger ;
  sflo:hasResourcePage <_mesh/_config/_history001/index.html> .

<_mesh/_config/_history001/_s0001> a sflo:HistoricalState ;
  sflo:stateOrdinal "1"^^xsd:nonNegativeInteger ;
  sflo:hasManifestation <_mesh/_config/_history001/_s0001/ttl> ;
  sflo:locatedFileForState <_mesh/_config/_history001/_s0001/ttl/config.ttl> ;
  sflo:hasResourcePage <_mesh/_config/_history001/_s0001/index.html> .

<_mesh/_config/_history001/_s0001/ttl> a sflo:ArtifactManifestation, sflo:RdfDocument ;
  sflo:locatedFileForManifestation <_mesh/_config/_history001/_s0001/ttl/config.ttl> ;
  sflo:hasResourcePage <_mesh/_config/_history001/_s0001/ttl/index.html> .

<_mesh/_config/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_config/_history001/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_config/_history001/_s0001/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_config/_history001/_s0001/ttl/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_meta/meta.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<examples/_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh/_config/config.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh/_config/_history001/_s0001/ttl/config.ttl> a sflo:LocatedFile, sflo:RdfDocument .

