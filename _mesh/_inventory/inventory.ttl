@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .
@prefix sfcfg: <https://semantic-flow.github.io/sflo/config/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<_mesh> a sflo:SemanticMesh ;
  sflo:meshBase "https://semantic-flow.github.io/mesh-branch-fantasy-rules/"^^xsd:anyURI ;
  sflo:hasMeshMetadata <_mesh/_meta> ;
  sflo:hasMeshInventory <_mesh/_inventory> ;
  sfcfg:hasConfig <_mesh/_config> ;
  sflo:hasResourcePage <_mesh/index.html> .

<_mesh/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_meta> a sflo:MeshMetadata, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <_mesh/_meta/meta.ttl> ;
  sflo:hasResourcePage <_mesh/_meta/index.html> .

<_mesh/_meta/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_inventory> a sflo:MeshInventory, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <_mesh/_inventory/inventory.ttl> ;
  sflo:hasResourcePage <_mesh/_inventory/index.html> .

<_mesh/_inventory/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_config> a sfcfg:MeshConfig, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <_mesh/_config/config.ttl> ;
  sflo:hasResourcePage <_mesh/_config/index.html> ;
  sflo:hasArtifactHistory <_mesh/_config/_history001> ;
  sflo:currentArtifactHistory <_mesh/_config/_history001> ;
  sflo:nextHistoryOrdinal "2"^^xsd:nonNegativeInteger .

<_mesh/_config/_history001> a sflo:ArtifactHistory ;
  sflo:historyOrdinal "1"^^xsd:nonNegativeInteger ;
  sflo:hasHistoricalState <_mesh/_config/_history001/_s0001> ;
  sflo:latestHistoricalState <_mesh/_config/_history001/_s0001> ;
  sflo:nextStateOrdinal "2"^^xsd:nonNegativeInteger ;
  sflo:hasResourcePage <_mesh/_config/_history001/index.html> .

<_mesh/_config/_history001/_s0001> a sflo:HistoricalState ;
  sflo:stateOrdinal "1"^^xsd:nonNegativeInteger ;
  sflo:hasManifestation <_mesh/_config/_history001/_s0001/ttl> ;
  sflo:locatedFileForState <_mesh/_config/_history001/_s0001/ttl/config.ttl> ;
  sflo:hasResourcePage <_mesh/_config/_history001/_s0001/index.html> .

<_mesh/_config/_history001/_s0001/ttl> a sflo:ArtifactManifestation, sflo:RdfDocument ;
  sflo:locatedFileForManifestation <_mesh/_config/_history001/_s0001/ttl/config.ttl> ;
  sflo:hasResourcePage <_mesh/_config/_history001/_s0001/ttl/index.html> .

<_mesh/_config/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_config/_history001/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_config/_history001/_s0001/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_config/_history001/_s0001/ttl/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh/_meta/meta.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh/_config/config.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh/_config/_history001/_s0001/ttl/config.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh> sflo:hasKnop <ontology/_knop> .

<ontology> a sflo:PayloadArtifact, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:workingLocalRelativePath "../source/ontology/fantasy-rules-ontology.ttl" .

<ontology/_knop> a sflo:Knop ;
  sflo:hasWorkingKnopInventoryFile <ontology/_knop/_inventory/inventory.ttl> .

<ontology/_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<ontology> sflo:hasResourcePage <ontology/index.html> .

<ontology/_knop> sflo:hasResourcePage <ontology/_knop/index.html> .

<ontology/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/_knop/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh> sflo:hasKnop <shacl/_knop> .

<shacl> a sflo:PayloadArtifact, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:workingLocalRelativePath "../source/shacl/fantasy-rules-shacl.ttl" .

<shacl/_knop> a sflo:Knop ;
  sflo:hasWorkingKnopInventoryFile <shacl/_knop/_inventory/inventory.ttl> .

<shacl/_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<shacl> sflo:hasResourcePage <shacl/index.html> .

<shacl/_knop> sflo:hasResourcePage <shacl/_knop/index.html> .

<shacl/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<shacl/_knop/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<_mesh> sflo:hasKnop <ontology/AbilityScore/_knop> .

<ontology/AbilityScore/_knop> a sflo:Knop ;
  sflo:hasWorkingKnopInventoryFile <ontology/AbilityScore/_knop/_inventory/inventory.ttl> .

<ontology/AbilityScore/_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh> sflo:hasKnop <ontology/Alignment/_knop> .

<ontology/Alignment/_knop> a sflo:Knop ;
  sflo:hasWorkingKnopInventoryFile <ontology/Alignment/_knop/_inventory/inventory.ttl> .

<ontology/Alignment/_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh> sflo:hasKnop <ontology/Character/_knop> .

<ontology/Character/_knop> a sflo:Knop ;
  sflo:hasWorkingKnopInventoryFile <ontology/Character/_knop/_inventory/inventory.ttl> .

<ontology/Character/_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh> sflo:hasKnop <ontology/PlayerCharacter/_knop> .

<ontology/PlayerCharacter/_knop> a sflo:Knop ;
  sflo:hasWorkingKnopInventoryFile <ontology/PlayerCharacter/_knop/_inventory/inventory.ttl> .

<ontology/PlayerCharacter/_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<_mesh> sflo:hasKnop <ontology/CharacterShape/_knop> .

<ontology/CharacterShape/_knop> a sflo:Knop ;
  sflo:hasWorkingKnopInventoryFile <ontology/CharacterShape/_knop/_inventory/inventory.ttl> .

<ontology/CharacterShape/_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<ontology/AbilityScore> sflo:hasResourcePage <ontology/AbilityScore/index.html> .

<ontology/AbilityScore/_knop> sflo:hasResourcePage <ontology/AbilityScore/_knop/index.html> .

<ontology/AbilityScore/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/AbilityScore/_knop/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/Alignment> sflo:hasResourcePage <ontology/Alignment/index.html> .

<ontology/Alignment/_knop> sflo:hasResourcePage <ontology/Alignment/_knop/index.html> .

<ontology/Alignment/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/Alignment/_knop/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/Character> sflo:hasResourcePage <ontology/Character/index.html> .

<ontology/Character/_knop> sflo:hasResourcePage <ontology/Character/_knop/index.html> .

<ontology/Character/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/Character/_knop/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/CharacterShape> sflo:hasResourcePage <ontology/CharacterShape/index.html> .

<ontology/CharacterShape/_knop> sflo:hasResourcePage <ontology/CharacterShape/_knop/index.html> .

<ontology/CharacterShape/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/CharacterShape/_knop/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/PlayerCharacter> sflo:hasResourcePage <ontology/PlayerCharacter/index.html> .

<ontology/PlayerCharacter/_knop> sflo:hasResourcePage <ontology/PlayerCharacter/_knop/index.html> .

<ontology/PlayerCharacter/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<ontology/PlayerCharacter/_knop/index.html> a sflo:ResourcePage, sflo:LocatedFile .
