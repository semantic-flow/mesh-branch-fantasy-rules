@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<examples/_knop> a sflo:Knop ;
  sflo:hasKnopMetadata <examples/_knop/_meta> ;
  sflo:hasKnopInventory <examples/_knop/_inventory> ;
  sflo:hasWorkingKnopInventoryFile <examples/_knop/_inventory/inventory.ttl> ;
  sflo:hasResourcePage <examples/_knop/index.html> .

<examples/_knop/_meta> a sflo:KnopMetadata, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <examples/_knop/_meta/meta.ttl> ;
  sflo:hasResourcePage <examples/_knop/_meta/index.html> .

<examples/_knop/_inventory> a sflo:KnopInventory, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasArtifactHistory <examples/_knop/_inventory/_history001> ;
  sflo:currentArtifactHistory <examples/_knop/_inventory/_history001> ;
  sflo:nextHistoryOrdinal "2"^^xsd:nonNegativeInteger ;
  sflo:hasWorkingLocatedFile <examples/_knop/_inventory/inventory.ttl> ;
  sflo:hasResourcePage <examples/_knop/_inventory/index.html> .

<examples/_knop/_inventory/_history001> a sflo:ArtifactHistory ;
  sflo:historyOrdinal "1"^^xsd:nonNegativeInteger ;
  sflo:hasHistoricalState <examples/_knop/_inventory/_history001/_s0001> ;
  sflo:latestHistoricalState <examples/_knop/_inventory/_history001/_s0001> ;
  sflo:nextStateOrdinal "2"^^xsd:nonNegativeInteger ;
  sflo:hasResourcePage <examples/_knop/_inventory/_history001/index.html> .

<examples/_knop/_inventory/_history001/_s0001> a sflo:HistoricalState ;
  sflo:stateOrdinal "1"^^xsd:nonNegativeInteger ;
  sflo:hasManifestation <examples/_knop/_inventory/_history001/_s0001/ttl> ;
  sflo:locatedFileForState <examples/_knop/_inventory/_history001/_s0001/ttl/inventory.ttl> ;
  sflo:hasResourcePage <examples/_knop/_inventory/_history001/_s0001/index.html> .

<examples/_knop/_inventory/_history001/_s0001/ttl> a sflo:ArtifactManifestation, sflo:RdfDocument ;
  sflo:locatedFileForManifestation <examples/_knop/_inventory/_history001/_s0001/ttl/inventory.ttl> ;
  sflo:hasResourcePage <examples/_knop/_inventory/_history001/_s0001/ttl/index.html> .

<examples/_knop/_meta/meta.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<examples/_knop/_inventory/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<examples/_knop/_inventory/_history001/_s0001/ttl/inventory.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<examples/_knop/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<examples/_knop/_meta/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<examples/_knop/_inventory/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<examples/_knop/_inventory/_history001/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<examples/_knop/_inventory/_history001/_s0001/index.html> a sflo:ResourcePage, sflo:LocatedFile .

<examples/_knop/_inventory/_history001/_s0001/ttl/index.html> a sflo:ResourcePage, sflo:LocatedFile .
