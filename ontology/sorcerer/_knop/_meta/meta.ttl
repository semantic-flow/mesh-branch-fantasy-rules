@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/sorcerer/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/sorcerer" ;
  sflo:hasWorkingKnopInventoryFile <ontology/sorcerer/_knop/_inventory/inventory.ttl> .
