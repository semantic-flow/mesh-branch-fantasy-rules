@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/ranger/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/ranger" ;
  sflo:hasWorkingKnopInventoryFile <ontology/ranger/_knop/_inventory/inventory.ttl> .
