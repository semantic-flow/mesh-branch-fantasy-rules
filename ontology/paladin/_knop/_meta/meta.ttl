@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/paladin/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/paladin" ;
  sflo:hasWorkingKnopInventoryFile <ontology/paladin/_knop/_inventory/inventory.ttl> .
