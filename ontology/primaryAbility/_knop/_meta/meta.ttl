@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/primaryAbility/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/primaryAbility" ;
  sflo:hasWorkingKnopInventoryFile <ontology/primaryAbility/_knop/_inventory/inventory.ttl> .
