@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/PlayerCharacter/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/PlayerCharacter" ;
  sflo:hasWorkingKnopInventoryFile <ontology/PlayerCharacter/_knop/_inventory/inventory.ttl> .
