@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/PlayerCharacter/_knop/_sources> a sflo:KnopSourceRegistry, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <ontology/PlayerCharacter/_knop/_sources/sources.ttl> ;
  sflo:hasSourceBinding <ontology/PlayerCharacter/_knop/_sources#extraction-source> .

<ontology/PlayerCharacter/_knop/_sources#extraction-source> a sflo:ExtractionSource ;
  sflo:hasTargetArtifact <ontology> ;
  sflo:hasRequestedTargetState <ontology/_history001/_s0001> ;
  sflo:hasObservedSourceState <ontology/_history001/_s0001> ;
  sflo:hasObservedSourceManifestation <ontology/_history001/_s0001/ttl> ;
  sflo:hasObservedSourceLocatedFile <ontology/_history001/_s0001/ttl/fantasy-rules-ontology.ttl> ;
  sflo:observedSourceDigest "sha256:cde2f0ac40fda47f3ecae3a5183825475119129540a3b773950954085f6e9f6f" .

<ontology/PlayerCharacter/_knop/_sources/sources.ttl> a sflo:LocatedFile, sflo:RdfDocument .
