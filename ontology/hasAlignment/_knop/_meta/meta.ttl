@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasAlignment/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasAlignment" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasAlignment/_knop/_inventory/inventory.ttl> .
