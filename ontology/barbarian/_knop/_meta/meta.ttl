@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/barbarian/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/barbarian" ;
  sflo:hasWorkingKnopInventoryFile <ontology/barbarian/_knop/_inventory/inventory.ttl> .
