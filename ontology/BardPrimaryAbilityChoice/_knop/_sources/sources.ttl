<ontology/BardPrimaryAbilityChoice/_knop/_sources> a sflo:KnopSourceRegistry, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <ontology/BardPrimaryAbilityChoice/_knop/_sources/sources.ttl> ;
  sflo:hasSourceBinding <ontology/BardPrimaryAbilityChoice/_knop/_sources#extraction-source> .

<ontology/BardPrimaryAbilityChoice/_knop/_sources#extraction-source> a sflo:ExtractionSource ;
  sflo:hasTargetArtifact <shacl> ;
  sflo:hasRequestedTargetState <shacl/releases/v0.0.2> ;
  sflo:hasObservedSourceState <shacl/releases/v0.0.2> ;
  sflo:hasObservedSourceManifestation <shacl/releases/v0.0.2/ttl> ;
  sflo:hasObservedSourceLocatedFile <shacl/releases/v0.0.2/ttl/fantasy-rules-shacl.ttl> ;
  sflo:observedSourceDigest "sha256:31211564c80fb496c0c47da840dc16c7b49b8d8c25c029b7b443dde8db3ad604" .

<ontology/BardPrimaryAbilityChoice/_knop/_sources/sources.ttl> a sflo:LocatedFile, sflo:RdfDocument .
