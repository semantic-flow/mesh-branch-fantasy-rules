@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/character/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/character" ;
  sflo:hasWorkingKnopInventoryFile <ontology/character/_knop/_inventory/inventory.ttl> .
