@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/wizard/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/wizard" ;
  sflo:hasWorkingKnopInventoryFile <ontology/wizard/_knop/_inventory/inventory.ttl> .
