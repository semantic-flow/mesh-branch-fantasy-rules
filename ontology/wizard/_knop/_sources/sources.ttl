@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/wizard/_knop/_sources> a sflo:KnopSourceRegistry, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <ontology/wizard/_knop/_sources/sources.ttl> ;
  sflo:hasSourceBinding <ontology/wizard/_knop/_sources#extraction-source> .

<ontology/wizard/_knop/_sources#extraction-source> a sflo:ExtractionSource ;
  sflo:hasTargetArtifact <ontology> ;
  sflo:hasRequestedTargetState <ontology/releases/v0.0.2> ;
  sflo:hasObservedSourceState <ontology/releases/v0.0.2> ;
  sflo:hasObservedSourceManifestation <ontology/releases/v0.0.2/ttl> ;
  sflo:hasObservedSourceLocatedFile <ontology/releases/v0.0.2/ttl/fantasy-rules-ontology.ttl> ;
  sflo:observedSourceDigest "sha256:f200a39ad022f1954d19527fa2307b1b5e29d8f3b468314488585a7b3ce8457b" .

<ontology/wizard/_knop/_sources/sources.ttl> a sflo:LocatedFile, sflo:RdfDocument .
