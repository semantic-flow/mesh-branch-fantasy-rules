@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasAbilityScore/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasAbilityScore" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasAbilityScore/_knop/_inventory/inventory.ttl> .
