@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/Alignment/neutralGood/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/Alignment/neutralGood" ;
  sflo:hasWorkingKnopInventoryFile <ontology/Alignment/neutralGood/_knop/_inventory/inventory.ttl> .
