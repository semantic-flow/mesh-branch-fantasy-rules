@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/cleric/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/cleric" ;
  sflo:hasWorkingKnopInventoryFile <ontology/cleric/_knop/_inventory/inventory.ttl> .
