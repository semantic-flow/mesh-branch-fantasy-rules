@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/wisdom/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/wisdom" ;
  sflo:hasWorkingKnopInventoryFile <ontology/wisdom/_knop/_inventory/inventory.ttl> .
