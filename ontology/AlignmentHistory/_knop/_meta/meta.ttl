@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/AlignmentHistory/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/AlignmentHistory" ;
  sflo:hasWorkingKnopInventoryFile <ontology/AlignmentHistory/_knop/_inventory/inventory.ttl> .
