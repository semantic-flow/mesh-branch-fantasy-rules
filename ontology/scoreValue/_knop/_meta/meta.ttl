@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/scoreValue/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/scoreValue" ;
  sflo:hasWorkingKnopInventoryFile <ontology/scoreValue/_knop/_inventory/inventory.ttl> .
