@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/fighter/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/fighter" ;
  sflo:hasWorkingKnopInventoryFile <ontology/fighter/_knop/_inventory/inventory.ttl> .
