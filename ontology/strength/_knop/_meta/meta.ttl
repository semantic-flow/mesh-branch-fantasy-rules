@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/strength/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/strength" ;
  sflo:hasWorkingKnopInventoryFile <ontology/strength/_knop/_inventory/inventory.ttl> .
