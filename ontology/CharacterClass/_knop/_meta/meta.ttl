@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/CharacterClass/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/CharacterClass" ;
  sflo:hasWorkingKnopInventoryFile <ontology/CharacterClass/_knop/_inventory/inventory.ttl> .
