@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/AbilityScore/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/AbilityScore" ;
  sflo:hasWorkingKnopInventoryFile <ontology/AbilityScore/_knop/_inventory/inventory.ttl> .
