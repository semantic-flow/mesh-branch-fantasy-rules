@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/Ability> sflo:hasReferenceLink <ontology/Ability/_knop/_references#reference001> .

<ontology/Ability/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/Ability> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
