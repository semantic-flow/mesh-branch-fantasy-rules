@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/Ability/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/Ability" ;
  sflo:hasWorkingKnopInventoryFile <ontology/Ability/_knop/_inventory/inventory.ttl> .
