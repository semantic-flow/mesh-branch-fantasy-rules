@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/warlock/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/warlock" ;
  sflo:hasWorkingKnopInventoryFile <ontology/warlock/_knop/_inventory/inventory.ttl> .
