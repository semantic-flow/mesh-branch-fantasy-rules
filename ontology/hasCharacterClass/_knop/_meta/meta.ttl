@base <https://semantic-flow.github.io/mesh-branch-fantasy-rules/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasCharacterClass/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasCharacterClass" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasCharacterClass/_knop/_inventory/inventory.ttl> .
